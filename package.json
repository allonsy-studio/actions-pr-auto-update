{
	"$schema": "https://www.schemastore.org/package.json",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"name": "actions-pr-auto-update",
	"version": "1.1.0",
	"description": "A configurable GitHub Action to keep pull requests up-to-date.",
	"license": "MIT",
	"author": "Cassondra Roberts <castastrophe@users.noreply.github.com> (https://allons-y.studio)",
	"contributors": [
		"Max Komarychev"
	],
	"homepage": "https://github.com/castastrophe/actions-pr-auto-update#readme",
	"funding": [
		{
			"type": "github",
			"url": " https://github.com/sponsors/castastrophe"
		},
		{
			"type": "buymeacoffee",
			"url": "https://www.buymeacoffee.com/castastrophe"
		}
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/castastrophe/actions-pr-auto-update.git"
	},
	"bugs": {
		"url": "https://github.com/castastrophe/actions-pr-auto-update/issues"
	},
	"type": "module",
	"main": "bin/index.js",
	"files": [
		"bin/index.js",
		"CHANGELOG.md",
		"README.md",
		"LICENSE",
		"package.json"
	],
	"scripts": {
		"build": "tsc --noEmit && node esbuild.config.js",
		"ci": "npm-run-all clean build format",
		"clean": "rm -rf bin",
		"coverage": "jest --coverage",
		"format": "yarn lint --fix",
		"lint": "eslint --no-error-on-unmatched-pattern --no-warn-ignored --cache '**/*'",
		"precommit": "lint-staged",
		"prepare": "husky && envoy || true",
		"semantic-release": "npm-run-all clean build format && semantic-release",
		"test": "jest"
	},
	"dependencies": {
		"@actions/core": "^3.0.1",
		"@actions/github": "^9.1.1"
	},
	"devDependencies": {
		"@allons-y/toolkit": "local:../toolkit",
		"@octokit/core": "^7.0.6",
		"husky": "^9.1.7",
		"npm-run-all": "^4.1.5"
	},
	"keywords": [
		"actions",
		"auto-update",
		"github",
		"pull-request",
		"update"
	],
	"engines": {
		"node": ">=24"
	},
	"packageManager": "yarn@4.14.1"
}
